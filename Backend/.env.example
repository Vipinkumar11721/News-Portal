# MongoDB Connection String
# For local development: mongodb://localhost:27017/NewsPortal
# For Render: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGOURI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Node Environment
NODE_ENV=production

# Server Port (Render assigns this automatically, but useful for local dev)
PORT=9000
